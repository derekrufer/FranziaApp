POSTGRES_USER=draft
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=fantasy_draft

# Backend container port. The compose file exposes this as 4000:4000 by default.
BACKEND_PORT=4000

# Frontend host port for NAS/Portainer access.
FRONTEND_PORT=8088

# Internal Docker database connection used by the backend.
DATABASE_URL=postgres://draft:change-this-password@postgres:5432/fantasy_draft

# Public browser origin for CORS when the backend is called directly.
# For Nginx Proxy Manager later, change this to your public app URL.
CLIENT_ORIGIN=http://localhost:8088

# Production frontend default is blank, which means same-origin API calls through Nginx.
# Local dev still defaults to http://localhost:4000 when this is unset.
VITE_API_BASE_URL=
